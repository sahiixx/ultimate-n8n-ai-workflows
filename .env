# Copy to .env and fill in your keys

# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
NODE_ENV=production

# LiteLLM Proxy
LITELLM_PORT=4000

# Provider API Keys
# At least one of these should be set. Anthropic is needed for Claude Sonnet.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
